# Uso con Django en el HOST (venv) + Compose solo para db/redis.
# Si corrés la app con Docker, usá el archivo comiteado docker/defaults.env (cargado por docker-compose.local.yml).
# Copiar a .env y ajustar (nunca commitear .env con secretos reales)

# Django
DJANGO_SECRET_KEY=dev-change-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (alineado con docker-compose: servicio "db")
POSTGRES_DB=challenge
POSTGRES_USER=challenge
POSTGRES_PASSWORD=challenge
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis (Celery)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_JOBS=job-events
KAFKA_CONSUMER_GROUP=downstream-processors
KAFKA_ENABLED=true
KAFKA_CLIENT_ID_PREFIX=gateway
