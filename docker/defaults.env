# Valores para correr el stack con Docker (red interna: db, redis, kafka).
# Cargado por docker-compose.local.yml; podés añadir override sin commitear en .env
# (ver README): docker compose acepta variables de sustitución desde un .env en la raíz.

# Django
DJANGO_SETTINGS_MODULE=config.settings
DJANGO_SECRET_KEY=dev-docker-not-for-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,api

# PostgreSQL — host es el servicio "db" en el compose
POSTGRES_DB=challenge
POSTGRES_USER=challenge
POSTGRES_PASSWORD=challenge
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis / Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
REDIS_URL=redis://redis:6379/0

# Kafka — listener interno del broker (PLAINTEXT) en el compose
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC_JOBS=job-events
KAFKA_CONSUMER_GROUP=downstream-processors
KAFKA_ENABLED=true
KAFKA_CLIENT_ID_PREFIX=gateway
